generator client {
  provider = "prisma-client-js"
  output= "../src/generated/prisma"
  moduleFormat= "cjs"

}

datasource db {
  provider = "mysql"


}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  firstName      String
  lastName       String
  role  role
  passwordHash  String

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model RegisterOtp {
  id                String   @id @default(uuid())
  email             String   @unique
  otpHash           String
  expiresAt         DateTime
  attemptsRemaining Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([email, expiresAt])
}

enum role {
  CUSTOMER
  ADMIN
}